# ─── Database (Neon) ──────────────────────────────────────────
# Neon pooled connection string (Dashboard → Connection Details → Pooled)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ─── Auth (JWT) ───────────────────────────────────────────────
# 32+ byte random secret, e.g. `openssl rand -base64 32`
JWT_SECRET=replace-with-a-long-random-secret
# Admin identity
ADMIN_EMAIL=admin@example.com
# bcrypt hash of the admin password, e.g.
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'yourpassword'
ADMIN_PASSWORD_HASH=$2a$10$replace.with.your.bcrypt.hash

# ─── Storage (Vercel Blob) ────────────────────────────────────
# Vercel Dashboard → Storage → Blob → create store → copy token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=

# ─── Misc ─────────────────────────────────────────────────────
GITHUB_USERNAME=
GITHUB_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
